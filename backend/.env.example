APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=namanpuja

# LLM: mock | groq | openai
LLM_PROVIDER=mock
USE_MOCK_LLM=true

# Groq (testing — https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — images (primary) + content fallback if Groq fails
GEMINI_API_KEY=
GEMINI_CONTENT_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# OpenAI (production)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

REDIS_URL=redis://localhost:6379/0
WORKER_QUEUE=batch_generation
JOB_MAX_RETRIES=3

CMS_BASE_URL=
CMS_API_KEY=
CMS_UPLOAD_ENABLED=false

USE_S3_STORAGE=false
AWS_REGION=us-east-1
S3_BUCKET=
S3_PUBLIC_BASE_URL=
LOCAL_IMAGE_DIR=../frontend/public/images

ALLOWED_ORIGINS=http://localhost:5173
API_KEYS=dev-api-key
ENFORCE_AUTH=false
TRUSTED_PROXY_IPS=

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_FAIL_CLOSED=false

BATCH_STUCK_MINUTES=30
PIPELINE_MAX_WORKERS=4
