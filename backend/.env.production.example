APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=namanpuja

OPENAI_API_KEY=replace-with-production-key
OPENAI_MODEL=gpt-4o-mini
USE_MOCK_LLM=false

REDIS_URL=redis://redis:6379/0
WORKER_QUEUE=batch_generation

CMS_BASE_URL=https://cms.namanpuja.com/api
CMS_API_KEY=replace-with-cms-key
CMS_UPLOAD_ENABLED=true

USE_S3_STORAGE=true
AWS_REGION=us-east-1
S3_BUCKET=namanpuja-production-assets
S3_PUBLIC_BASE_URL=https://cdn.namanpuja.com

ALLOWED_ORIGINS=https://admin.namanpuja.com
API_KEYS=replace-with-strong-api-key
ENFORCE_AUTH=true
TRUSTED_HOSTS=admin.namanpuja.com,api.namanpuja.com

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
